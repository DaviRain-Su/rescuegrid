# RescueGrid frontend env. Copy to .env.local and fill in.
# All optional — without them the app runs in self-contained demo mode (mock data).

# RescueGrid Worker base URL (Phase E). Dev: `cd worker && npm run dev` then:
VITE_WORKER_URL=http://localhost:8787

# Real zkLogin via Enoki (https://portal.enoki.mystenlabs.com).
# Create an Enoki project -> copy the PUBLIC api key (frontend) here.
VITE_ENOKI_API_KEY=enoki_public_...

# Google OAuth client ID (Google Cloud Console -> OAuth 2.0 Client, Web app).
# Register the same client ID in the Enoki portal, and add your app origin
# (e.g. http://localhost:5173) as an authorized redirect/JavaScript origin.
VITE_GOOGLE_CLIENT_ID=...apps.googleusercontent.com
